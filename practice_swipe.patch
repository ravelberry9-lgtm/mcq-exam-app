-<script>
-const FOLDER = '{{ folder }}';
-const TOPIC  = '{{ topic }}';
-
-let allQuestions   = [];
-let filteredQs     = [];
-let currentIdx     = 0;
-let correct        = 0;
-let wrong          = 0;
-let answered       = 0;
-let filterMode     = 'all';
-let started        = false;
-
-// ── Load questions ──────────────────────────────────────────────────────────
-async function load() {
-  try {
-    const r = await fetch(`/api/practice-questions/${FOLDER}/${TOPIC}`);
-    const d = await r.json();
-    allQuestions = d.questions || [];
-    document.getElementById('loadingWrap').style.display = 'none';
-    if (!allQuestions.length) {
-      document.getElementById('questionArea').innerHTML = '<div class="empty-state">No questions found for this topic.</div>';
-      return;
-    }
-    showIntro();
-  } catch(e) {
-    document.getElementById('loadingWrap').innerHTML = '<p style="color:red;padding:40px">Failed to load questions.</p>';
-  }
-}
-
-function showIntro() {
-  const q = filteredQs.length || allQuestions.length;
-  document.getElementById('introTitle').textContent = TOPIC.replace(/_/g,' ') + ' Practice';
-  document.getElementById('introDesc').textContent =
-    `${allQuestions.length} questions ready. Tap an option to instantly see right/wrong with explanation.`;
-  document.getElementById('introCard').style.display = '';
-}
-
-// ── Filters ─────────────────────────────────────────────────────────────────
-function setFilter(mode, btn) {
-  filterMode = mode;
-  document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('active'));
-  btn.classList.add('active');
-  if (started) {
-    // Apply filter mid-session: restart with filtered set
-    applyFilter();
-    restartPractice();
-  }
-}
-
-function applyFilter() {
-  if (filterMode === 'all') {
-    filteredQs = [...allQuestions];
-  } else {
-    filteredQs = allQuestions.filter(q => q.difficulty === filterMode);
-  }
-  // Shuffle
-  for (let i = filteredQs.length - 1; i > 0; i--) {
-    const j = Math.floor(Math.random() * (i + 1));
-    [filteredQs[i], filteredQs[j]] = [filteredQs[j], filteredQs[i]];
-  }
-}
-
-// ── Start / Restart ──────────────────────────────────────────────────────────
-function startPractice() {
-  started = true;
-  applyFilter();
-  if (!filteredQs.length) {
-    alert('No questions match the selected filter.');
-    return;
-  }
-  currentIdx = 0; correct = 0; wrong = 0; answered = 0;
-  document.getElementById('introCard').style.display = 'none';
-  document.getElementById('summaryCard').classList.remove('show');
-  buildCards();
-  showQuestion(0);
-}
-
-function restartPractice() {
-  document.getElementById('summaryCard').classList.remove('show');
-  document.getElementById('questionArea').innerHTML = '';
-  startPractice();
-}
-
-// ── Build all question cards (hidden) ────────────────────────────────────────
-function buildCards() {
-  const area = document.getElementById('questionArea');
-  area.innerHTML = '';
-  filteredQs.forEach((q, idx) => {
-    const card = document.createElement('div');
-    card.className = 'q-card';
-    card.id = 'qc_' + idx;
-
-    const opts = [
-      {key:'A', text: q.option_a},
-      {key:'B', text: q.option_b},
-      {key:'C', text: q.option_c},
-      {key:'D', text: q.option_d},
-    ];
-
-    const diffClass = q.difficulty === 'Easy' ? 'diff-Easy'
-                    : q.difficulty === 'Hard' ? 'diff-Hard' : 'diff-Medium';
-
-    card.innerHTML = `
-      <div class="q-meta">
-        <span class="q-num">Q ${idx + 1} of ${filteredQs.length}</span>
-        <span class="diff-badge ${diffClass}">${q.difficulty}</span>
-      </div>
-      <div class="q-text">${escHtml(q.question_text)}</div>
-      <div class="options-list" id="opts_${idx}">
-        ${opts.map(o => `
-          <button class="opt-btn" id="opt_${idx}_${o.key}"
-                  onclick="selectOption(${idx},'${o.key}','${escAttr(q.correct_answer)}','${escAttr(q.explanation || '')}')">
-            <span class="opt-key">${o.key}</span>
-            <span class="opt-text">${escHtml(o.text)}</span>
-          </button>
-        `).join('')}
-      </div>
-    `;
-    area.appendChild(card);
-  });
-}
-
-// ── Show a question ──────────────────────────────────────────────────────────
-function showQuestion(idx) {
-  // Hide all cards, feedback, next
-  document.querySelectorAll('.q-card').forEach(c => c.classList.remove('visible'));
-  document.getElementById('feedbackPanel').classList.remove('show');
-  document.getElementById('nextWrap').classList.remove('show');
-
-  if (idx >= filteredQs.length) { showSummary(); return; }
-
-  const card = document.getElementById('qc_' + idx);
-  if (card) card.classList.add('visible');
-  updateProgress(idx);
-}
-
-// ── Handle option tap ────────────────────────────────────────────────────────
-function selectOption(idx, chosen, correctAns, explanation) {
-  // Lock all options for this card
-  const optList = document.getElementById('opts_' + idx);
-  if (!optList) return;
-  const buttons = optList.querySelectorAll('.opt-btn');
-  if (buttons[0].classList.contains('locked')) return; // already answered
-
-  buttons.forEach(btn => btn.classList.add('locked'));
-  answered++;
-
-  const isCorrect = chosen === correctAns;
-  if (isCorrect) correct++; else wrong++;
-
-  // Highlight chosen option
-  const chosenBtn = document.getElementById(`opt_${idx}_${chosen}`);
-  chosenBtn.classList.add(isCorrect ? 'correct-ans' : 'wrong-ans');
-
-  // Always show correct answer
-  if (!isCorrect) {
-    const correctBtn = document.getElementById(`opt_${idx}_${correctAns}`);
-    if (correctBtn) correctBtn.classList.add('correct-ans');
-  }
-
-  // Show feedback panel
-  const panel = document.getElementById('feedbackPanel');
-  const label = document.getElementById('fbLabel');
-  const expEl = document.getElementById('fbExplanation');
-
-  panel.className = 'feedback-panel show ' + (isCorrect ? 'correct-fb' : 'wrong-fb');
-  label.textContent = isCorrect ? '✅ Correct!' : '❌ Incorrect!';
-  expEl.textContent = explanation || (isCorrect ? 'Well done!' : 'Review the correct answer above.');
-
-  // Show Next button
